<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">
       
       
       <bean id="emp1" class=" beans.Employee">
       
       <property name="employeeId" value="1223"></property>
        <property name="employeeName" value="ashu"></property>
         <property name="salary" value="60000"></property>
          <property name="businessUnit" ref="sbu"></property>
           <property name="age" value="23"></property>
       </bean>
       <bean id="sbu" class="beans.SBU">
        <property name="sbuId" value="1"></property>
        <property name="sbuName" value="PES-BU"></property>
         <property name="sbuHead" value="Ashu yadav"></property>
       </bean>
       
       </beans>